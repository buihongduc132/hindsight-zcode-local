{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${ZCODE_PLUGIN_ROOT}/dist/session-start.cjs",
            "timeoutMs": 60000,
            "statusMessage": "🧠 Hindsight draining queue…"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${ZCODE_PLUGIN_ROOT}/dist/recall.cjs",
            "timeoutMs": 300000,
            "statusMessage": "🧠 Hindsight recalling…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${ZCODE_PLUGIN_ROOT}/dist/retain.cjs",
            "timeoutMs": 330000,
            "statusMessage": "🧠 Hindsight retaining…"
          }
        ]
      }
    ]
  }
}
