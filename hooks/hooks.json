{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${ZCODE_PLUGIN_ROOT}/dist/recall.cjs",
            "timeoutMs": 30000,
            "statusMessage": "🧠 Hindsight recalling…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${ZCODE_PLUGIN_ROOT}/dist/retain.cjs",
            "async": true,
            "timeout": 45,
            "timeoutMs": 45000,
            "statusMessage": "🧠 Hindsight retaining…"
          }
        ]
      }
    ]
  }
}
