{
  "enabled": true,
  "timeoutMs": 30000,
  "maxOutputBytes": 65536,
  "events": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${ZCODE_PLUGIN_ROOT}/dist/recall.cjs",
            "timeout": 30,
            "timeoutMs": 30000,
            "statusMessage": "🧠 Hindsight recalling…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${ZCODE_PLUGIN_ROOT}/dist/retain.cjs",
            "timeout": 45,
            "timeoutMs": 45000,
            "statusMessage": "🧠 Hindsight retaining…",
            "async": true
          }
        ]
      }
    ]
  }
}
